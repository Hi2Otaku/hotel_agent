# =============================================================
# HotelBook Production Environment Variables
# Copy to .env and fill in strong random values
# =============================================================

# Database passwords (set strong random values)
AUTH_DB_PASSWORD=CHANGE_ME
ROOM_DB_PASSWORD=CHANGE_ME
BOOKING_DB_PASSWORD=CHANGE_ME

# RabbitMQ
RABBITMQ_PASS=CHANGE_ME

# Admin account
ADMIN_EMAIL=admin@hotelbook.com
ADMIN_PASSWORD=CHANGE_ME

# JWT Keys (RS256 PEM format)
# The CI/CD deploy job writes these to files on the server.
# Values should contain the full PEM content (base64-encoded in GitHub Secrets).
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME
